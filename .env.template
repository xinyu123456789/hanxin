# ============================================================
# 涵心 · 環境變數範本
# 複製為 .env 後填入真實值（.env 不進版控）
# ============================================================

DJANGO_SECRET_KEY=change-me-use-django-get-random-secret-key

DJANGO_DEBUG=True

# PostgreSQL 連線字串
# 格式：postgres://使用者:密碼@主機:埠/資料庫名
DATABASE_URL=postgres://hanxin:yourpassword@localhost:5432/hanxin_db

# Redis 連線字串
REDIS_URL=redis://localhost:6379/0

# 欄位加密金鑰（Fernet，32 bytes base64）
# 產生方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=your-fernet-key-here

# Gemini API（平台統一金鑰，全站功能共用）
GEMINI_API_KEY=AIza你的金鑰

# 各功能各自使用的模型（皆有預設值，可不填）
GEMINI_MODEL_CHAT=gemini-2.5-flash
GEMINI_MODEL_EMOTION=gemini-2.5-flash-lite
GEMINI_MODEL_REVIEW=gemini-2.5-flash

# 生產環境才需要填（prod.py 用）
